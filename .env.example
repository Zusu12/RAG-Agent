# =============================================================
# RAGAgent Environment Configuration
# =============================================================
# Get your free token at: https://huggingface.co/settings/tokens
# Create a "Read" access token — that's all you need.
# =============================================================

# HuggingFace API Token (required for HF Inference API)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx

# Text generation model (via HF Inference API)
# Recommended options:
#   mistralai/Mistral-7B-Instruct-v0.3  (fast, high quality)
#   HuggingFaceH4/zephyr-7b-beta        (great alternative)
#   meta-llama/Llama-3.1-8B-Instruct    (requires Meta license acceptance)
HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# Embedding model (local, via sentence-transformers)
# Options: all-mpnet-base-v2 (better quality), all-MiniLM-L6-v2 (faster)
EMBEDDING_MODEL=all-mpnet-base-v2

# ChromaDB persistence directory
CHROMA_DIR=./chroma_db

# Chunk settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
